generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  //url      = env("DATABASE_URL") //Apenas para calar a boca do prisma
}

enum UserRole {
  user
  admin
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  teamID String?
  team   Team?   @relation(fields: [teamID], references: [id])

  tasks Task[]

  role UserRole @default(user)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Team {
  id          String  @id @default(uuid())
  name        String
  description String?

  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("teams")
}

enum TaskPriority {
  Baixa
  Media
  Alta
}

enum TaskStatus {
  Pendente
  Andamento
  Concluida
}

enum TaskType {
  Movimentacao
  Admissao
}

model Task {
  id String @id @default(uuid())

  servidor     String
  matricula    Int
  entrada      String
  emailEntrada String
  saida        String?
  isTotal      Boolean?
  //carga
  emailSaida   String?
  cargo        String
  funcao       String
  cargaHoraria String
  inicio       String
  expedicao    String
  isMemorando  Boolean
  number       Int?

  tipo        TaskType
  description String?

  enviado Boolean @default(false)

  status   TaskStatus   @default(Pendente)
  priority TaskPriority

  userID String?
  user   User?   @relation(fields: [userID], references: [id])

  tasklogs TaskLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tasks")
}

model TaskLog {
  id          String     @id @default(uuid())
  status      TaskStatus
  description String?

  taskID String
  task   Task   @relation(fields: [taskID], references: [id])

  createdAt DateTime @default(now())

  @@map("taskLogs")
}

// Schema para Carências

model Escola {
  id   Int    @id @default(autoincrement())
  nome String @unique

  turmas    Turma[]
  carencias CarenciaDocente[]
  gradeHorarios GradeHorario[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("escolas")
}

model Turma {
  id            String         @id @default(uuid())
  escolaId      Int            @map("escola_id")
  escola        Escola         @relation(fields: [escolaId], references: [id])
  codigoTurma   String         @map("codigo_turma")
  idEcidade     Int?           @unique @map("id_ecidade")
  turno         Turno
  gradeHorarios GradeHorario[]

  @@map("turmas")
}

model Disciplina {
  id            String         @id @default(uuid())
  sigla         String         @unique
  nomeCompleto  String?        @map("nome_completo")
  corHex        String         @map("cor_hex")
  gradeHorarios GradeHorario[]
  professores   Professor[]

  @@map("disciplinas")
}

model Professor {
  matricula     String         @id
  nome          String
  cargaHoraria  Int
  disciplinaId  String         @map("disciplina_id")
  disciplina    Disciplina     @relation(fields: [disciplinaId], references: [id])

  gradesTitular    GradeHorario[] @relation("Titular")
  gradesSubstituto GradeHorario[] @relation("Substituto")

  @@map("professores")
}

model GradeHorario {
  id      String @id @default(uuid())
  turmaId String @map("turma_id")
  turma   Turma  @relation(fields: [turmaId], references: [id])

  escolaId Int    @map("escola_id")
  escola   Escola @relation(fields: [escolaId], references: [id])

  professorMatricula String?    @map("professor_matricula")
  professor          Professor? @relation("Titular", fields: [professorMatricula], references: [matricula])

  substitutoMatricula String?    @map("substituto_matricula")
  substituto          Professor? @relation("Substituto", fields: [substitutoMatricula], references: [matricula])

  disciplinaId String     @map("disciplina_id")
  disciplina   Disciplina @relation(fields: [disciplinaId], references: [id])

  diaSemana   DiaSemana   @map("dia_semana")
  tempo       Int
  tipoVinculo TipoVinculo @default(PRINCIPAL) @map("tipo_vinculo")

  tipoCarencia TipoCarencia? @map("tipo_carencia")

  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  @@unique([turmaId, diaSemana, tempo])
  @@map("grade_horario")
}

model CarenciaDocente {
  id       String @id @default(uuid())
  escolaId Int    @map("escola_id")
  escola   Escola @relation(fields: [escolaId], references: [id])

  disciplina         String
  turno              String
  diaSemana          Int
  horarioTempo       Int
  turma              Int?
  tipo               TipoCarencia @default(REAL)
  professorCobertura String?

  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([escolaId, disciplina, turno, diaSemana, horarioTempo])
  @@map("carencias_docentes")
}

// ==========================================
// ENUMS
// ==========================================

enum Turno {
  MANHA
  TARDE
  NOITE
  INTEGRAL
}

enum DiaSemana {
  SEG
  TER
  QUA
  QUI
  SEX
}

enum TipoVinculo {
  PRINCIPAL
  SUBSTITUTO
  CARENCIA
}

enum TipoCarencia {
  REAL
  TEMPORARIA
  REAL_COBERTA
  TEMPORARIA_COBERTA
}
