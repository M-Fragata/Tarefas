generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  teamID    String?
  role      UserRole @default(user)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]
  team      Team?    @relation(fields: [teamID], references: [id])

  @@map("users")
}

model Team {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]

  @@map("teams")
}

model Task {
  id           String       @id @default(uuid())
  description  String?
  status       TaskStatus   @default(Pendente)
  priority     TaskPriority
  userID       String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  entrada      String
  matricula    Int
  saida        String?
  servidor     String
  tipo         TaskType
  cargaHoraria String
  cargo        String
  emailEntrada String
  emailSaida   String?
  enviado      Boolean      @default(false)
  expedicao    String
  funcao       String
  inicio       String
  isMemorando  Boolean
  number       Int?
  isTotal      Boolean?
  copiaPara    String[]
  tasklogs     TaskLog[]
  user         User?        @relation(fields: [userID], references: [id])

  @@map("tasks")
}

model TaskLog {
  id          String     @id @default(uuid())
  taskID      String
  createdAt   DateTime   @default(now())
  status      TaskStatus
  description String?
  task        Task       @relation(fields: [taskID], references: [id])

  @@map("taskLogs")
}

model Escola {
  id            Int               @id @default(autoincrement())
  nome          String            @unique
  createdAt     DateTime          @default(now()) @map("created_at")
  carencias     CarenciaDocente[]
  gradeHorarios GradeHorario[]
  turmas        Turma[]

  @@map("escolas")
}

model Turma {
  id            String         @id @default(uuid())
  escolaId      Int            @map("escola_id")
  codigoTurma   String         @map("codigo_turma")
  idEcidade     Int?           @unique @map("id_ecidade")
  turno         Turno
  gradeHorarios GradeHorario[]
  escola        Escola         @relation(fields: [escolaId], references: [id])

  @@map("turmas")
}

model Disciplina {
  id            String         @id @default(uuid())
  sigla         String         @unique
  nomeCompleto  String?        @map("nome_completo")
  corHex        String         @map("cor_hex")
  gradeHorarios GradeHorario[]
  professores   Professor[]

  @@map("disciplinas")
}

model Professor {
  matricula        String         @id
  nome             String
  cargaHoraria     Int
  disciplinaId     String         @map("disciplina_id")
  gradesTitular    GradeHorario[] @relation("Titular")
  gradesSubstituto GradeHorario[] @relation("Substituto")
  disciplina       Disciplina     @relation(fields: [disciplinaId], references: [id])

  @@map("professores")
}

model GradeHorario {
  id                  String        @id @default(uuid())
  turmaId             String        @map("turma_id")
  professorMatricula  String?       @map("professor_matricula")
  disciplinaId        String        @map("disciplina_id")
  diaSemana           DiaSemana     @map("dia_semana")
  tempo               Int
  tipoVinculo         TipoVinculo   @default(PRINCIPAL) @map("tipo_vinculo")
  atualizadoEm        DateTime      @updatedAt @map("atualizado_em")
  escolaId            Int           @map("escola_id")
  substitutoMatricula String?       @map("substituto_matricula")
  tipoCarencia        TipoCarencia? @map("tipo_carencia")
  disciplina          Disciplina    @relation(fields: [disciplinaId], references: [id])
  escola              Escola        @relation(fields: [escolaId], references: [id])
  professor           Professor?    @relation("Titular", fields: [professorMatricula], references: [matricula])
  substituto          Professor?    @relation("Substituto", fields: [substitutoMatricula], references: [matricula])
  turma               Turma         @relation(fields: [turmaId], references: [id])

  @@unique([turmaId, diaSemana, tempo])
  @@map("grade_horario")
}

model CarenciaDocente {
  id                 String       @id @default(uuid())
  escolaId           Int          @map("escola_id")
  disciplina         String
  turno              String
  diaSemana          Int
  horarioTempo       Int
  turma              Int?
  tipo               TipoCarencia @default(REAL)
  professorCobertura String?
  updatedAt          DateTime     @updatedAt @map("updated_at")
  escola             Escola       @relation(fields: [escolaId], references: [id])

  @@unique([escolaId, disciplina, turno, diaSemana, horarioTempo])
  @@map("carencias_docentes")
}

model CargosEcidade {
  id    String @id @default(uuid())
  value Int
  cargo String

  @@map("Cargos_ecidade")
}

enum UserRole {
  user
  admin
}

enum TaskPriority {
  Baixa
  Media
  Alta
}

enum TaskStatus {
  Pendente
  Andamento
  Concluida
}

enum TaskType {
  Movimentacao
  Admissao
}

enum Turno {
  MANHA
  TARDE
  NOITE
  INTEGRAL
}

enum DiaSemana {
  SEG
  TER
  QUA
  QUI
  SEX
}

enum TipoVinculo {
  PRINCIPAL
  SUBSTITUTO
  CARENCIA
}

enum TipoCarencia {
  REAL
  TEMPORARIA
  REAL_COBERTA
  TEMPORARIA_COBERTA
}
